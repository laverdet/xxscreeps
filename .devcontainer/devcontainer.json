{
	"name": "xxscreeps",
	"dockerFile": "Dockerfile",
	"build": {
		"args": {
			"LLVM_VERSION": "22"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"llvm-vs-code-extensions.vscode-clangd",
				"twxs.cmake"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "bash",
						"args": [ "-l" ],
						"icon": "terminal-bash"
					}
				}
			}
		}
	},
	"mounts": [
		"source=/etc/localtime,target=/etc/localtime,type=bind,readonly"
	],
	"features": {
		"ghcr.io/devcontainers/features/github-cli": {},
		"ghcr.io/devcontainers/features/node:2": {
			"nodeGypDependencies": false,
			"pnpmVersion": "latest",
			"version": "24"
		}
	},
	// '_devcontainer_init' may be defined by dotfiles. this is different than the 'install' script
	// because dotfiles runs before the repo is setup.
	"postStartCommand": [ "/bin/sh", "-cl", "which -s _devcontainer_init && _devcontainer_init || true" ],
	"runArgs": [ "--net=host" ],
	"workspaceMount": "source=${localWorkspaceFolder},target=/xxscreeps,type=bind",
	"workspaceFolder": "/xxscreeps"
}
