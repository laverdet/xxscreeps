{
  "name": "@xxscreeps/pathfinder",
  "type": "commonjs",
  "version": "0.3.0",
  "main": "./dist/pathfinder.mjs",
  "imports": {
    "#pf": {
      "import": "./module/index.cjs",
      "types": "./module/index.d.cts"
    }
  },
  "scripts": {
    "prepublishOnly": "napi prepublish --no-gh-release"
  },
  "napi": {
    "binaryName": "pf",
    "targets": [
      "aarch64-alpine-linux-musl",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-alpine-linux-musl",
      "x86_64-apple-darwin",
      "x86_64-pc-windows",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@auto_js/js": "^0.0.5",
    "@auto_js/napi": "^0.0.5",
    "@auto_js/v8": "^0.0.5",
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "~24.12.2",
    "isolated-vm": "6.0.2",
    "nan": "2.25.0"
  },
  "homepage": "https://github.com/laverdet/xxscreeps/blob/main/packages/pathfinder/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laverdet/xxscreeps.git"
  }
}
