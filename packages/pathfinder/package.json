{
  "name": "@xxscreeps/pathfinder",
  "type": "module",
  "version": "0.4.3",
  "exports": {
    ".": "./dist/pf.js",
    "./iv": "./dist/iv.js"
  },
  "imports": {
    "#pf": {
      "import": "./module/pf.js",
      "types": "./module/pf.d.ts"
    },
    "#iv": {
      "import": "./module/iv.js",
      "types": "./module/iv.d.ts"
    }
  },
  "scripts": {
    "prepublishOnly": "napi prepublish --no-gh-release"
  },
  "napi": {
    "binaryName": "pf",
    "targets": [
      "aarch64-alpine-linux-musl",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-alpine-linux-musl",
      "x86_64-apple-darwin",
      "x86_64-pc-windows",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "dependencies": {
    "@isolated-vm/experimental": "^0.0.10"
  },
  "devDependencies": {
    "@auto_js/js": "^0.0.9",
    "@auto_js/napi": "^0.0.9",
    "@auto_js/v8": "^0.0.9",
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "~24.12.2",
    "isolated-vm": "6.0.2",
    "nan": "2.25.0"
  },
  "homepage": "https://github.com/laverdet/xxscreeps/blob/main/packages/pathfinder/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laverdet/xxscreeps.git"
  }
}
