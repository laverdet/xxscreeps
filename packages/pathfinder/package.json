{
  "name": "@xxscreeps/pathfinder",
  "type": "commonjs",
  "version": "0.1.0",
  "main": "./module/index.js",
  "scripts": {
    "configure": "cmake -DCMAKE_BUILD_TYPE=Release \"-DCMAKE_MODULE_PATH:PATH=$(pnpm exec auto_js_cmake_include)\" -G Ninja -B build",
    "configure:dev": "cmake -DCMAKE_BUILD_TYPE=Debug \"-DCMAKE_MODULE_PATH:PATH=$(pnpm exec auto_js_cmake_include)\" -G Ninja -B build",
    "build": "npm run configure && cmake --build build",
    "clean": "cmake -B build --target clean",
    "prepublishOnly": "napi prepublish --no-gh-release",
    "install": "echo congratulations"
  },
  "napi": {
    "binaryName": "pf",
    "targets": [
      "aarch64-alpine-linux-musl",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-alpine-linux-musl",
      "x86_64-apple-darwin",
      "x86_64-pc-windows",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@auto_js/js": "^0.0.1",
    "@auto_js/napi_exports": "^0.0.1",
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "~24.12.2",
    "isolated-vm": "6.0.2",
    "nan": "2.25.0"
  },
  "homepage": "https://github.com/laverdet/xxscreeps/blob/main/packages/pathfinder/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laverdet/xxscreeps.git"
  }
}
