{
	"compilerOptions": {
		// Enable project references
		"composite": true,

		// Sources
		"rootDir": "${configDir}",
		"outDir": "${configDir}/dist",

		// Language & emit settings
		"sourceMap": true,
		// nb: There was a v8 bug in earlier versions of nodejs v24.x affecting explicit resource
		// management. So we'll rely on 'tslib' until nodejs v26.
		"target": "es2022",

		// Options
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"importHelpers": true,
		"moduleResolution": "nodenext",
		"module": "nodenext",
		"lib": [ "esnext", "dom" ],
		"resolveJsonModule": true,
		"types": [],

		// Strictness
		"isolatedModules": true,
		"exactOptionalPropertyTypes": true,
		"noEmitOnError": false,
		"noImplicitOverride": true,
		// TODO: Re-enable this when nodejs types have been fixed
		"skipLibCheck": true,
		"strict": true,
	},
	"include": [ "${configDir}", "${configDir}/**/*.json" ],
	"exclude": [ "**/dist", "**/node_modules", "**/package.json", "**/tsconfig.json" ],
	"files": [],
	"references": [],
}
